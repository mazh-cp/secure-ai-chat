# Application Configuration
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Storage Configuration (optional - defaults to ./.storage)
# STORAGE_DIR=./.storage

# One shared file + RAG corpus for the whole deployment (all browsers use the same owner_id).
# Value must match [a-zA-Z0-9_-]+ (e.g. org or acme-corp). Leave unset for per-browser isolation (default).
# SECURITY: Anyone who can use the app can upload/delete/clear this shared corpus — protect with network/auth if needed.
# SHARED_ORG_OWNER_ID=org

# Application Metadata (safe to expose to client)
NEXT_PUBLIC_APP_NAME=Secure AI Chat
# Bump to match package.json when cutting a release (avoids header/UI drift vs deployed code).
NEXT_PUBLIC_APP_VERSION=1.1.13

# API Keys (optional - can be configured via Settings UI)
# These are stored securely in .secure-storage/ and should NOT be committed
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# Google Gemini (Google AI Studio). Prefer GEMINI_API_KEY; GOOGLE_API_KEY is also accepted.
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# LAKERA_AI_KEY=
# LAKERA_API_KEY=   # alternate env name (same Guard token); LAKERA_AI_KEY wins if both set
# LAKERA_PROJECT_ID=
# LAKERA_ENDPOINT=   # Full Guard URL, e.g. https://api.lakera.ai/v2/guard or https://eu-west-1.api.lakera.ai/v2/guard (not /v1/guard)
# On Lakera HTTP errors: production defaults to fail-closed (block) except 401 (bad key — no Guard run).
# Set LAKERA_FAIL_CLOSED=false for fail-open on all errors. Set LAKERA_FAIL_CLOSED_ON_AUTH_ERROR=1 to block on 401 too.
# LAKERA_FAIL_CLOSED=
# LAKERA_FAIL_CLOSED_ON_AUTH_ERROR=
# Hardened posture (production): one switch enables require-project-id, forced chat input/output scans, and 401 blocking when fail-closed.
# LAKERA_ENFORCE_STRICT=
# Or set individually: LAKERA_REQUIRE_PROJECT_ID=1  LAKERA_ENFORCE_INPUT_OUTPUT_SCAN=1
# After a successful Guard call (200, unflagged), merge local regex pre-scan as prompt injection (legacy).
# Default off so Lakera portal policy is authoritative. Set to 1 only if you want dual-layer overrides.
# LAKERA_PRESCAN_MERGE_AFTER_GUARD=
# Pilot/shadow mode: run Lakera Guard but do NOT block on Guard flags (policy calibration only).
# Hard-blocks (local prescan hits, infrastructure errors) still apply. NOT for hardened production.
# LAKERA_GUARD_MONITORING_ONLY=
# Chat input Guard scanning scope. Default: augmented (scan after RAG/file context injection).
# Set to 'raw' to scan only the original user message (minimal demo parity / debugging).
# LAKERA_GUARD_INPUT_SCOPE=
# In production with a Lakera key, project_id is required by default (Guard uses your tuned policy).
# Set to 'false' only if you intentionally want Lakera's default policy instead of your project policy.
# LAKERA_REQUIRE_PROJECT_ID=
# CHECKPOINT_TE_API_KEY=
# CHECKPOINT_TE_ENCRYPTION_KEY=
# API_KEYS_ENCRYPTION_KEY=
# Install directory for durable .secure-storage (GUI keys, TE key, PIN). `npm start` standalone sets this automatically.
# SECURE_AI_CHAT_APP_ROOT=/opt/secure-ai-chat

# Optional app-wide password login (SECURE_CHAT_*). Session cookie `Secure` flag:
# auto from HTTPS / X-Forwarded-Proto; use SESSION_COOKIE_SECURE=0 for internal HTTP-only prod.
# SESSION_COOKIE_SECURE=
# When TLS terminates at a reverse proxy and cookies/login break: set TRUST_PROXY_HTTPS=1 so Secure session cookies match browser HTTPS.
# TRUST_PROXY_HTTPS=

# Security Note: 
# - Never commit API keys to git
# - API keys stored via Settings UI are encrypted in .secure-storage/
# - .secure-storage/ and .storage/ are in .gitignore
# - Only NEXT_PUBLIC_APP_NAME and NEXT_PUBLIC_APP_VERSION are safe to expose to client
